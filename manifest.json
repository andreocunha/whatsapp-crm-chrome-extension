{
  "manifest_version": 3,
  "name": "Assis Extensão",
  "description": "Captura o número logado, contatos e fotos de perfil do WhatsApp Web.",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icon_16.png",
    "32": "assets/icon_32.png",
    "48": "assets/icon_48.png",
    "128": "assets/icon_128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WhatsApp Info"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
